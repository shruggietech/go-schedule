# Binaries / build output
/bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Generated Windows resource object (created in CI from versioninfo.json + icon.ico)
*.syso

# Test & coverage artifacts
*.test
*.out
coverage.*

# Go workspace / module cache
go.work
go.work.sum
vendor/

# Local runtime data (SQLite store, sockets, logs)
*.db
*.db-shm
*.db-wal
*.sock
*.log

# Agent folders — may contain credentials/auth tokens (flagged by spec-kit init).
# Exclude everything, then narrowly admit the skills subtree: a fresh clone
# otherwise has no /speckit-* commands and no house standards, which
# docs/build-autopilot.md names as a setup failure. This is an allowlist on
# purpose — a denylist would admit every agent file nobody thought of, and the
# excluded material is credential-bearing by assumption.
.claude/*
!.claude/skills/

# Locally installed sqlite3 for the maintainer test scripts (never committed;
# the repo detects or installs on request, it does not vendor binaries).
test/scripts/.bin/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# Local build output
dist/
